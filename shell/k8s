#!/bin/bash

# Auto completion — generated once into the omz completions dir, then loaded
# by compinit on later shells (no subprocess spawn on every shell).
_comp_dir="$HOME/.oh-my-zsh/completions"
command -v kubectl   &>/dev/null && [ ! -f "$_comp_dir/_kubectl" ]   && kubectl completion zsh   > "$_comp_dir/_kubectl"
command -v helm      &>/dev/null && [ ! -f "$_comp_dir/_helm" ]      && helm completion zsh      > "$_comp_dir/_helm"
command -v kustomize &>/dev/null && [ ! -f "$_comp_dir/_kustomize" ] && kustomize completion zsh > "$_comp_dir/_kustomize"
unset _comp_dir

kubecli() {
  NAMESPACE=""
  IDENTIFIER=$(tr -dc a-z0-9 </dev/urandom | head -c 10)
  CONTAINER_NAME="remote-cli-${IDENTIFIER}"

  if [[ -n "$1" ]]; then
    NAMESPACE="-n $1"
  fi

  echo "Starting ${CONTAINER_NAME}"

  # busybox:1.35
  /bin/bash -c "kubectl run ${NAMESPACE} -it ${CONTAINER_NAME} --rm --image=alpine:3 --restart=Never -- /bin/sh"
}

kube-local-proxy() {
  KUBE_LOCAL="k3s-local"
  CURRENT_CTX=$(kubectx -c)
  PORT=${1:-8443}

  if [ "$CURRENT_CTX" != "$KUBE_LOCAL" ]; then
    echo "Switching to $KUBE_LOCAL"
    kubectx "$KUBE_LOCAL"
  fi

  echo -e "\n${COLOR_GREEN}Access ArgoCD Web UI:${COLOR_RESET} ${COLOR_YELLOW}https://127.0.0.1:${PORT}${COLOR_RESET}\n"

  kubectl -n argocd port-forward svc/argocd-server ${PORT}:443
}

# Alias kubectl/k to kubecolor if installed, else fall back to kubectl
if command -v kubecolor &>/dev/null; then
  alias kubectl='kubecolor'
  alias k='kubecolor'
  compdef kubecolor=kubectl 2>/dev/null
else
  command -v k &>/dev/null || alias k='kubectl'
fi

# Add krew to path (https://krew.sigs.k8s.io/)
export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"
