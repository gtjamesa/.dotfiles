#!/bin/bash

# Pure environment + PATH only — sourced by .zshenv for every shell
# (incl. non-interactive / Xcode). Slow tool init lives in loader, not here.

# File editor
export VISUAL=vim
export EDITOR="$VISUAL"

# Homebrew. Fresh Linux installs use apt/dnf (no linuxbrew), but machines that
# already have linuxbrew keep working — the -x guards no-op when brew is absent.
# macOS: Apple Silicon /opt/homebrew, Intel /usr/local.
if [ -x /home/linuxbrew/.linuxbrew/bin/brew ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
elif [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# dotfiles bin
export PATH="$HOME/.dotfiles/shell/bin:$PATH"

# Composer
export PATH="$HOME/.composer/vendor/bin:$PATH"

# Node / Yarn — fnm (Fast Node Manager)
# Put fnm's default node on PATH without invoking the fnm binary, so
# non-interactive shells (Xcode build phases, cron) get `node` for free.
# loader runs the full `fnm env` for interactive shells.
# On Linux the --skip-shell installer drops fnm at $FNM_DIR/fnm; on macOS
# brew puts it on PATH already, so the check below just no-ops.
export FNM_DIR="$HOME/.local/share/fnm"
[ -x "$FNM_DIR/fnm" ] && export PATH="$FNM_DIR:$PATH"
[ -x "$FNM_DIR/aliases/default/bin/node" ] && \
  export PATH="$FNM_DIR/aliases/default/bin:$PATH"
export PATH="$HOME/.yarn/bin:$HOME/.config/yarn/global/node_modules/.bin:$PATH"

# pipx
export PATH="$HOME/.local/bin:$HOME/.local:$PATH"

# golang
export GOPATH="$HOME/go"
export PATH="/usr/local/go/bin:$GOPATH/bin:$PATH"

# Rust (cargo)
[ -f "$HOME/.cargo/env" ] && source "$HOME/.cargo/env"

# Python (pyenv) — PATH only; `pyenv init` runs in loader (interactive)
export PYENV_ROOT="$HOME/.pyenv"
command -v pyenv >/dev/null || export PATH="$PYENV_ROOT/bin:$PATH"

# asdf (Go binary, 0.16+) — no asdf.sh to source; the shims dir on PATH is what
# resolves installed tool versions. Binary: ~/.local/bin (Linux) / brew (macOS).
export PATH="${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"

# Kubernetes
export PATH="$HOME/.kubescape/bin:$PATH"

# claude
export ENABLE_LSP_TOOL=1

# Custom Software
export PATH="/opt:$PATH"
export PATH=$PATH:$HOME/.maestro/bin

# Sentinel — loader checks this to skip a redundant re-source on non-Darwin.
export DOTFILES_EXPORTS_LOADED=1
