#!/bin/bash

source "$HOME/.dotfiles/shell/helpers/distro"

SMB_CONF_FILE="/etc/samba/smb.conf"

smb_conf() {
  cat << EOF
[Projects]
   comment = ${USER}'s projects
   path = ${HOME}
   guest ok = no
   writeable = yes
   write list = ${USER}
   browseable = yes
   create mask = 0644
   directory mask = 0755
EOF
}

create_smb_share() {
  if [ ! -f "${SMB_CONF_FILE}" ]; then
    conf_content=$(smb_conf)
    echo -e "\n\nCreating ${SMB_CONF_FILE}..."
    echo "${conf_content}" > "${SMB_CONF_FILE}"
  else
    echo -e "\n\n${SMB_CONF_FILE} already exists, please add the following:\n"
    smb_conf
  fi
}

sudo -v

# Read username
echo -n "Enter your Windows username: "
read USERNAME

# Read password
stty -echo
echo -n "Enter your Windows password: "
read PASSWORD
stty echo
echo -e "\n"

case "$DOTFILES_PKG" in
  apt) sudo apt install -y samba ;;
  dnf) sudo dnf install -y samba ;;
esac
create_smb_share

# Create local SMB user
echo -e "${PASSWORD}\n${PASSWORD}\n" | sudo smbpasswd -L -a ${USERNAME}
# Enable the user
sudo smbpasswd -L -e ${USERNAME}

# Fedora's unit is `smb`, Debian's is `smbd` — pick whichever exists
if systemctl list-unit-files | grep -q '^smbd\.service'; then
  sudo systemctl restart smbd
else
  sudo systemctl restart smb
fi

# Fedora SELinux blocks Samba from serving $HOME by default — flip the
# persistent policy boolean so the share at path=$HOME actually works
[ "$DOTFILES_DISTRO" = fedora ] && sudo setsebool -P samba_enable_home_dirs on

# Show instructions
exec ./map
