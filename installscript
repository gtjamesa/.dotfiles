#!/bin/bash

# Load helper functions
source "$HOME/.dotfiles/shell/helpers/helpers"
source "$HOME/.dotfiles/shell/helpers/distro"

OS="$(uname)"
wsl2=0
composer=
docker=
getracker=
ask_optional=0

if [ "$OS" == "Linux" ]; then
  SHARE_PATH="/usr/share"
elif [ "$OS" == "Darwin" ]; then
  if [ -d /opt/homebrew/share ]; then
    SHARE_PATH="/opt/homebrew/share"
  else
    SHARE_PATH="/usr/local/share"
  fi
fi

for opt in "$@"; do
  case $opt in
  --help)
    echo "Please run the bootstrap script"
    exit 0
    ;;
  --all)
    composer=1
    docker=1
    getracker=1
    wsl2=0
    ;;
  --force-wsl2) wsl2=1 ;;
  --composer) composer=1 ;;
  --no-composer) composer=0 ;;
  --docker) docker=1 ;;
  --no-docker) docker=0 ;;
  --getracker) getracker=1 ;;
  --no-getracker) getracker=0 ;;
  --ask-optional) ask_optional=1 ;;
  *)
    echo "unknown option: $opt"
    echo "Please run the bootstrap script"
    exit 1
    ;;
  esac
done

detect_wsl() {
  [ "$OS" == "Linux" ] || return 0
  [ -f /proc/sys/fs/binfmt_misc/WSLInterop ] && wsl2=1
  grep -qi Microsoft /proc/version 2>/dev/null && wsl2=1
  grep -qi Microsoft /proc/sys/kernel/osrelease 2>/dev/null && wsl2=1
}

# Install ohmyzsh
# https://github.com/ohmyzsh/ohmyzsh
install_zsh() {
  # The zsh package itself is installed in the core-package batch (run_installer).
  echo "Installing ohmyzsh"
  echo "--------------------"
  rm -rf "$HOME/.oh-my-zsh/"
  backup_file ~/.zshrc
  sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
  ln -sf "$HOME/.dotfiles/shell/.zshrc" "$HOME/.zshrc"
  ln -s "$HOME/.dotfiles/themes/james-custom.zsh-theme" "$HOME/.oh-my-zsh/themes/"

  echo "Installing ZSH tools"
  echo "--------------------"

  if [[ ! -d "$SHARE_PATH/zsh-autosuggestions" ]]; then
    sudo git clone https://github.com/zsh-users/zsh-autosuggestions.git "$SHARE_PATH/zsh-autosuggestions"
  fi

  if [[ ! -d "$SHARE_PATH/zsh-syntax-highlighting" ]]; then
    sudo git clone https://github.com/zsh-users/zsh-syntax-highlighting.git "$SHARE_PATH/zsh-syntax-highlighting"
  fi
}

install_tmux() {
  echo "Installing tmux plugins"
  echo "-----------------------"

  # tmux itself is installed in the core-package batch (run_installer).
  # Add tmux plugins (tpm)
  mkdir -p "$HOME/.tmux/plugins"
  [ ! -d "$HOME/.tmux/plugins/tpm" ] && \
    git clone https://github.com/tmux-plugins/tpm "$HOME/.tmux/plugins/tpm"

  # Add tmux config
  symlink_file "$HOME/.dotfiles/shell/.tmux.conf" "$HOME/.tmux.conf"
}

install_fzf() {
  # The fzf package is installed in the core-package batch. Distro packages
  # wire up key-bindings/completion at runtime (see loader); only brew needs
  # its install script to generate ~/.fzf.zsh.
  if [ "$DOTFILES_PKG" = brew ]; then
    echo "Configuring fzf"
    echo "---------------"
    "$(brew --prefix)"/opt/fzf/install --key-bindings --completion --no-update-rc
  fi
}

# Install homebrew (macOS only — Linux uses apt/dnf directly)
# https://brew.sh
install_homebrew() {
  echo "Installing homebrew"
  echo "--------------------"
  NONINTERACTIVE=1 bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  else
    eval "$(/usr/local/bin/brew shellenv)"
  fi
}

install_dotfiles() {
  # Add global gitignore
  symlink_file "$HOME/.dotfiles/shell/.global-gitignore" "$HOME/.global-gitignore"
  git config --global core.excludesfile "$HOME/.global-gitignore"

  # Add vimrc
  symlink_file "$HOME/.dotfiles/shell/.vimrc" "$HOME/.vimrc"

  # Add zshenv (env for non-interactive / GUI / Xcode shells)
  symlink_file "$HOME/.dotfiles/shell/.zshenv" "$HOME/.zshenv"
}

install_node() {
  # Install fnm (Fast Node Manager). The official installer uses brew on macOS
  # and downloads a binary on Linux; --skip-shell stops it editing .zshrc
  # (loader handles fnm init itself).
  # https://github.com/Schniz/fnm
  curl -fsSL https://fnm.vercel.app/install | bash -s -- --skip-shell

  # Make fnm reachable in this script (Linux installer drops it in ~/.local/share/fnm)
  export PATH="$HOME/.local/share/fnm:$PATH"

  # Bring up fnm env for the rest of the installer
  eval "$(fnm env --shell bash)"

  # Install latest LTS node and set as default
  fnm install --lts
  fnm default "$(fnm current)"

  # Source pnpm helper now that node is on PATH
  [ -f "$HOME/.dotfiles/shell/js/pnpm" ] && source "$HOME/.dotfiles/shell/js/pnpm"

  # Install pnpm, yarn and release-it
  dotfiles-install-node-pms
}

install_python() {
  # Install pyenv. macOS uses brew; Linux clones the repo (not in apt/dnf).
  case "$DOTFILES_PKG" in
    brew) brew install pyenv ;;
    *)    [ ! -d "$HOME/.pyenv" ] && git clone https://github.com/pyenv/pyenv.git "$HOME/.pyenv" ;;
  esac

  # Install Python build dependencies
  # https://github.com/pyenv/pyenv/wiki#suggested-build-environment
  case "$DOTFILES_PKG" in
    apt)
      sudo apt update -y
      sudo apt install -y \
        make build-essential libssl-dev zlib1g-dev \
        libbz2-dev libreadline-dev libsqlite3-dev wget curl llvm \
        libncursesw5-dev xz-utils tk-dev libxml2-dev libxmlsec1-dev libffi-dev liblzma-dev \
        python3.10-dev openssl
      ;;
    dnf)
      sudo dnf install -y \
        @development-tools openssl-devel zlib-devel \
        bzip2-devel readline-devel sqlite-devel wget curl llvm \
        ncurses-devel xz xz-devel tk-devel libxml2-devel xmlsec1-devel libffi-devel \
        openssl
      ;;
    brew)
      brew install openssl readline sqlite3 xz zlib tcl-tk
      ;;
  esac

  # Put pyenv on PATH for the calls below (git-clone path needs this; brew
  # already did). install/global don't need `pyenv init` — only the PATH.
  export PYENV_ROOT="$HOME/.pyenv"
  command -v pyenv >/dev/null || export PATH="$PYENV_ROOT/bin:$PATH"

  pyenv install 3.10
  pyenv global 3.10

  # Should we reinstall it?
  # brew install openssl@1.1
}

install_asdf() {
  # asdf 0.16+ is a single Go binary. macOS uses brew; Linux fetches the latest
  # GitHub release into ~/.local/bin (on PATH via shell/exports). asdf_fetch_binary
  # is shared with shell/bin/asdf-migrate (the legacy → 0.16 upgrade script).
  source ~/.dotfiles/shell/helpers/asdf
  asdf_fetch_binary || { echo "asdf: binary install failed, skipping"; return 0; }

  symlink_file "$HOME/.dotfiles/shell/.tool-versions" "$HOME/.tool-versions"

  # No asdf.sh in 0.16+ — the shims dir (added to PATH in shell/exports) is
  # enough. asdf-reload installs the plugins/tool-versions.
  asdf-reload
}

install_wslu() {
  if [ "$wsl2" -eq 0 ]; then
    return 0
  fi

  # https://github.com/wslutilities/wslu
  case "$DOTFILES_PKG" in
    apt)
      sudo add-apt-repository -y ppa:wslutilities/wslu
      sudo apt update -y
      sudo apt install -y wslu
      ;;
    dnf)
      sudo dnf install -y wslu
      ;;
  esac

  [ ! -f /usr/local/bin/xdg-open ] && sudo ln -s /usr/bin/wslview /usr/local/bin/xdg-open

  # Enable the WSL shell module
  source "$HOME/.dotfiles/shell/helpers/dotmod"
  dotmod enable wsl

