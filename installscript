if [[ "$ask_optional" -eq 1 ]]; then

  run_preinstall
  install_optional
  exit 0

else

  run_installer

fi

# Change default shell
echo "Changing default shell to zsh, please authenticate:"
chsh -s $(which zsh)

echo "#################################"
echo
echo "- When running tmux for the first time"
echo "-- Press prefix + I (capital i, as in Install) to fetch the plugins"
echo
if [[ "$docker" -eq 1 ]]; then
  echo "- You may have to logout/login for Docker to work properly"
  echo
fi
if [[ "$OS" == "Linux" ]]; then
  echo "- To install desktop apps (Jetbrains, 1Password, etc.) run:"
  echo -e "  \033[0;34m~/.dotfiles/install/desktop/install\033[0m"
  echo
fi
echo "#################################"
