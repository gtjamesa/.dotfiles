install_macos() {
  # macOS-only setup — guarded by OS check in run_installer.

  # Show hidden files in Finder
  defaults write com.apple.finder AppleShowAllFiles -boolean true

  # macOS dev tooling (zstd/jq come via apt on Linux)
  brew install rbenv htop zstd jq ccache openssl@3

  # Initialise rbenv and install the latest stable Ruby so `gem install`
  # lands in rbenv's user-writable prefix (system Ruby on macOS is not
  # gem-writable without sudo).
  eval "$(rbenv init - bash)"
  local ruby_ver
  ruby_ver=$(rbenv install -l 2>/dev/null | grep -E '^[[:space:]]*[0-9.]+[[:space:]]*$' | tail -1 | tr -d '[:space:]')
  if [ -n "$ruby_ver" ]; then
    rbenv install -s "$ruby_ver"
    rbenv global "$ruby_ver"
    rbenv rehash
  fi

  # Ruby gems for iOS/macOS development (via rbenv's Ruby)
  gem install bundler
  gem install cocoapods
}

install_getracker() {
  if [[ "$getracker" -eq 1 ]]; then
    source "$HOME/.dotfiles/shell/helpers/dotmod"
    dotmod enable getracker
  fi
}

install_composer() {
  if [[ "$composer" -eq 1 ]]; then
    source "$HOME/.dotfiles/install/composer.sh"
  fi
}

install_docker() {
  # Docker on macOS means Docker Desktop — install it manually, skip here
  if [[ "$OS" == "Darwin" ]]; then
    return 0
  fi

  # Install Docker if enabled
  if [[ "$docker" -eq 1 ]]; then
    echo "Install Docker"

    # WSL 2 prep: enable systemd
    if [[ "$wsl2" -eq 1 ]] && [ ! -f /etc/wsl.conf ]; then
      cat <<EOF | sudo tee /etc/wsl.conf
[boot]
systemd=true
EOF
    fi

    # Upstream installer handles both apt and dnf distros, including
    # repo setup and signing keys. Replaces the previous apt-only path.
    # https://docs.docker.com/engine/install/
    curl -fsSL https://get.docker.com -o /tmp/get-docker.sh
    sudo bash /tmp/get-docker.sh
    rm -f /tmp/get-docker.sh

    # Ubuntu 22.04 + WSL 2 needs iptables-legacy. Fedora uses nftables; never needed.
    if [[ "$wsl2" -eq 1 ]] && [ "$DOTFILES_DISTRO" = debian ]; then
      SYS_VERS=$(grep VERSION_ID /etc/os-release | awk -F'"' '{print $2}')
      if [[ "$SYS_VERS" == "22.04" ]]; then
        echo -e "\033[0;33mEnsure to select 'iptables-legacy' when prompted\033[0m"
        sudo update-alternatives --config iptables
      fi
    fi

    # Compose V2 is a CLI plugin (`docker compose`), not the legacy standalone
    # docker-compose binary. get.docker.com sets up Docker's package repo and
    # usually pulls the plugin in; install it explicitly to be sure.
    # https://docs.docker.com/compose/install/#plugin-linux-only
    case "$DOTFILES_PKG" in
      apt) sudo apt install -y docker-compose-plugin ;;
      dnf) sudo dnf install -y docker-compose-plugin ;;
    esac

    # Back-compat shim: the Compose plugin provides only `docker compose`, no
    # hyphenated binary. Symlink the repo-tracked shim onto the system PATH (not
    # just a shell alias) so legacy callers work everywhere — scripts, Makefiles,
    # cron — which an interactive-only alias can't reach. sudo (not symlink_file)
    # since /usr/local/bin is root-owned; -f overwrites the old standalone
    # docker-compose binary that used to live at this path.
    sudo ln -sf "$HOME/.dotfiles/install/docker-compose" /usr/local/bin/docker-compose

    # Enable docker at startup and add user to group
    sudo systemctl start docker
    sudo systemctl enable docker
    sudo usermod -a -G docker "$USER"
  fi
}

install_optional() {
  # Install optional requirements
  install_getracker
  install_composer
  install_docker
}

fix_wsl() {
  [ "$wsl2" -eq 0 ] && return 0

  # When systemd is enabled, we may encounter "exec format error" when running windows binaries
  # https://github.com/microsoft/WSL/issues/8952#issuecomment-1568212651
  if [ ! -f /usr/lib/binfmt.d/WSLInterop.conf ]; then
    sudo sh -c 'echo :WSLInterop:M::MZ::/init:PF > /usr/lib/binfmt.d/WSLInterop.conf'
    sudo systemctl restart systemd-binfmt
  fi
}

ask_options() {
  # Composer
  if [[ -z "$composer" ]]; then
    confirm "Do you want to install PHP/Composer?"
    composer=$?
  fi

  # Docker
  if [[ -z "$docker" ]]; then
    confirm "Do you want to install or configure Docker?"
    docker=$?
  fi

  # GE Tracker
  if [[ -z "$getracker" ]]; then
    confirm "Do you want to install GE Tracker specific aliases?"
    getracker=$?
  fi
}

run_preinstall() {
  # Ask user their installation preferences for optional requirements
  ask_options

  # Detect whether the installer is running inside WSL
  # This will install (or not!) some other tools
  detect_wsl

  # Disable Ubuntu MOTD
  touch "$HOME/.hushlogin"
}

run_installer() {
  run_preinstall

  # Homebrew first so the core-package batch below can use `brew`.
  [ "$DOTFILES_PKG" = brew ] && install_homebrew

  # Core packages — one transaction per package manager is much faster than
  # invoking apt/dnf/brew once per tool. Tools needing extra setup keep their
  # own functions below (oh-my-zsh, tpm, fzf key-bindings). zoxide is a plain
  # package, not asdf: its asdf-plugins entry points at a deleted repo
  # (github.com/nyrst/asdf-zoxide, 404); loader inits it lazily.
  case "$DOTFILES_PKG" in
    apt)
      sudo apt update -y
      sudo apt install -y \
        build-essential curl file git wget vim jq zip unzip zstd xclip \
        zsh tmux fzf zoxide
      ;;
    dnf)
      sudo dnf install -y \
        @development-tools curl file git wget vim jq zip unzip zstd xclip wl-clipboard \
        zsh tmux fzf zoxide
      ;;
    brew)
      brew install zsh tmux fzf zoxide
      ;;
  esac

  #sudo apt install -y linux-headers-$(uname -r) dnsutils

  install_zsh
  install_dotfiles
  install_tmux
  install_fzf
  install_node
  install_python
  install_asdf
  install_wslu

  # macOS-specific setup
  if [[ "$OS" == "Darwin" ]]; then
    install_macos
  fi

  install_optional
  fix_wsl
}

